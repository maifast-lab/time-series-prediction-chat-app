NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Public Google OAuth client ID used by Google Identity Services in the browser.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin API base URL. This app stores no business data locally and depends on
# this API for auth, chats, suggestions, sheet rows, and data-source records.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Server-side Python cleaner API used before saving uploaded CSV/XLSX data
# through Admin. Do not expose this directly to the browser in production.
PYTHON_BACKEND_URL=http://127.0.0.1:8000/api/
